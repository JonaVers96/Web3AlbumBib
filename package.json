{
  "name": "webservices-album",
  "version": "1.0.0",
  "description": "Application Web Services.",
  "main": "index.ts",
  "repository": "git@github.com:HOGENT-frontendweb/frontendweb-2425-JonaVers96.git",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "concurrently -n api,web \"yarn dev:api\" \"yarn dev:web\"",
    "dev:api": "tsx watch --env-file .env src/index.ts",
    "dev:web": "cd frontend && npm run dev",
    "install:all": "yarn install && (cd frontend && npm install)",
    "build:all": "yarn build && yarn --cwd frontend build",
    "lint:all": "yarn lint && yarn --cwd frontend lint",
    "start:dev": "tsx watch --env-file .env src/index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "migrate:dev": "prisma migrate dev",
    "migrate:test": "env-cmd -f .env.test prisma migrate dev --skip-seed",
    "test": "env-cmd -f .env.test jest --runInBand",
    "test:reset": "env-cmd -f .env.test prisma migrate reset --force --skip-generate --skip-seed",
    "test:coverage": "yarn test:reset && env-cmd -f .env.test jest --runInBand --coverage"
  },
  "prisma": {
    "schema": "src/data/schema.prisma",
    "seed": "tsx ./src/data/seed.ts"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^3.0.0",
    "@koa/router": "^12.0.1",
    "@mollie/api-client": "^4.4.0",
    "@prisma/client": "^5.19.1",
    "@types/helmet": "^4.0.0",
    "@types/koa-helmet": "^6.0.8",
    "all": "^0.0.0",
    "argon2": "^0.41.1",
    "config": "^3.3.12",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-helmet": "^8.0.1",
    "koa-mount": "^4.0.0",
    "koa-static": "^5.0.0",
    "koa2-swagger-ui": "^5.11.0",
    "multer": "^2.0.2",
    "prisma": "^5.19.1",
    "swagger-jsdoc": "^6.2.8",
    "winston": "^3.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@stylistic/eslint-plugin": "^2.8.0",
    "@types/config": "^3.3.4",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-mount": "^4.0.5",
    "@types/koa-static": "^4.0.4",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__multer": "^2.0.8",
    "@types/koa__router": "^12.0.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.2.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "concurrently": "^9.0.0",
    "env-cmd": "^10.1.0",
    "eslint": "^9.10.0",
    "eslint-plugin-jest": "^28.8.3",
    "jest": "^29.7.0",
    "openapi-types": "^12.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.17.0",
    "typescript": "~5.5.4",
    "typescript-eslint": "^8.5.0"
  },
  "engines": {
    "node": ">=20.9.0 <21",
    "yarn": "1.22.22"
  }
}
